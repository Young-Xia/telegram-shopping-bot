# Copy to .env and fill in real values.
# Prefer the GUI Setup tab (打开控制面板.bat) if you are not sure.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:replace_me

# Optional. Comma-separated numeric user IDs. Empty = anyone can use the bot.
ALLOWED_TELEGRAM_USER_IDS=

# --- AI (OpenAI-compatible Chat Completions) ---
# OpenRouter / OpenAI / DeepSeek / Groq / Together / LM Studio / Ollama, etc.
AI_API_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=sk-deepseek-replace_me
AI_DEFAULT_MODEL=deepseek-chat
AI_MODELS=deepseek-chat

# Photo recognition — required when the chat API above has no vision (e.g. DeepSeek)
AI_VISION_API_BASE_URL=https://openrouter.ai/api/v1
AI_VISION_API_KEY=sk-or-v1-replace_me
AI_VISION_MODEL=google/gemini-2.5-flash

# Legacy aliases (still supported; GUI can migrate them):
# OPENROUTER_API_KEY=...
# OPENROUTER_DEFAULT_MODEL=...
# OPENROUTER_VISION_MODEL=...
# OPENROUTER_MODELS=...

# --- Web search used by some link helpers (not /search AI chat) ---
SEARCH_PROVIDER=duckduckgo
SEARCH_RESULT_COUNT=5

# Only if SEARCH_PROVIDER=google
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# --- Notion ---
# Token: ntn_... or secret_...  Database must Connect this integration.
# See NOTION-SETUP.md
NOTION_TOKEN=ntn_replace_me
NOTION_DATABASE_ID=replace_me

# Property names — match your database columns (Chinese defaults below).
# Missing URL / notes / category / images columns may be auto-created.
NOTION_TITLE_PROPERTY=名称
NOTION_URL_PROPERTY=链接
NOTION_CATEGORY_PROPERTY=分类
NOTION_STATUS_PROPERTY=状态
NOTION_STATUS_PROPERTY_TYPE=status
NOTION_DEFAULT_STATUS=未开始
NOTION_NOTES_PROPERTY=备注
NOTION_IMAGES_PROPERTY=图片
NOTION_ADDED_AT_PROPERTY=Added At
