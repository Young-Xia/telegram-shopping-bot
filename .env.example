# Telegram
TELEGRAM_BOT_TOKEN=123456:replace_me

# Optional but strongly recommended. Comma-separated Telegram numeric user IDs.
# If set, only users can use the bot.
ALLOWED_TELEGRAM_USER_IDS=

# AI API (OpenAI-compatible Chat Completions)
# Works with OpenRouter, OpenAI, DeepSeek, Groq, Together, LM Studio, Ollama, etc.
AI_API_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=sk-deepseek-replace_me
AI_DEFAULT_MODEL=deepseek-chat
AI_MODELS=deepseek-chat

# Photo recognition — required when the chat API above does not support vision (e.g. DeepSeek)
AI_VISION_API_BASE_URL=https://openrouter.ai/api/v1
AI_VISION_API_KEY=sk-or-v1-replace_me
AI_VISION_MODEL=google/gemini-2.5-flash

# Legacy aliases (still supported, auto-migrated in GUI):
# OPENROUTER_API_KEY=...
# OPENROUTER_DEFAULT_MODEL=...
# OPENROUTER_VISION_MODEL=...
# OPENROUTER_MODELS=...

# Search: duckduckgo works without API keys (default)
SEARCH_PROVIDER=duckduckgo
SEARCH_RESULT_COUNT=5

# Optional Google Custom Search (only if SEARCH_PROVIDER=google)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Notion
NOTION_TOKEN=secret_replace_me
NOTION_DATABASE_ID=replace_me

# Notion property names — optional if your DB only has title + status (bot auto-detects).
# Example for Chinese DB with 名称 + 状态:
# NOTION_TITLE_PROPERTY=名称
# NOTION_URL_PROPERTY=链接
# NOTION_CATEGORY_PROPERTY=分类
# NOTION_STATUS_PROPERTY=状态
# NOTION_DEFAULT_STATUS=未开始
# NOTION_NOTES_PROPERTY=备注
NOTION_TITLE_PROPERTY=名称
NOTION_URL_PROPERTY=链接
NOTION_CATEGORY_PROPERTY=分类
NOTION_STATUS_PROPERTY=状态
NOTION_STATUS_PROPERTY_TYPE=status
NOTION_DEFAULT_STATUS=未开始
NOTION_NOTES_PROPERTY=备注
NOTION_IMAGES_PROPERTY=图片
NOTION_ADDED_AT_PROPERTY=Added At
